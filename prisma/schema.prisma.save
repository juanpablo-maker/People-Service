// People MVP - Database Schema
// PostgreSQL with Prisma ORM
// Roles: CUSTOMER | PROFESSIONAL

generator client {
  provider = "prisma-client-js"
}

datasource db B  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROFESSIONAL
}

enum BookingStatus {
  PENDING      // Awaiting professional response
  ACCEPTED     // Professional accepted
  REJECTED     // Professional rejected
  CONFIRMED    // Payment held, confirmed
  IN_PROGRESS  // Service in progress
  COMPLETED    // Done, payment released
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique // Clerk auth ID for sync
  email     String
  name      String?
  role      UserRole
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  professionalProfile ProfessionalProfile?
  bookingsAsCustomer Booking[]           @relation("CustomerBookings")
  bookingsAsProfessional Booking[]        @relation("ProfessionalBookings")
  reviewsWritten      Review[]            @relation("ReviewsByCustomer")
}

model ProfessionalProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  bio                 String?
  yearsExperience     Int      @default(0)
  basePrice           Decimal  @db.Decimal(10, 2) // hourly in cents or smallest currency unit
  emergencyMultiplier Decimal  @db.Decimal(3, 2) @default(1.5) // e.g. 1.5x for emergency
  emergencyAvailable  Boolean  @default(false)
  ratingAverage       Decimal  @db.Decimal(3, 2) @default(0) // 0-5, computed from reviews
  totalReviews        Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  services Service[]
  reviews  Review[]
}

model Service {
  id            String   @id @default(cuid())
  name          String   // e.g. "Home Cleaning", "Deep Cleaning"
  category      String   // matches SERVICE_CATEGORIES in app
  professionalId String
  createdAt     DateTime @default(now())

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([category])
}

model Booking {
  id              String        @id @default(cuid())
  customerId      String
  professionalId  String
  serviceType     String        // category or "custom"
  customService   String?       // if serviceType === "custom"
  dateTime        DateTime
  address         String
  propertyType    String        // apartment, house, office
  size            String?       // sqm or rooms
  bathrooms       Int           @default(1)
  hasPets         Boolean       @default(false)
  description     String?
  emergency       Boolean       @default(false)
  // Add-ons stored as JSON array: ["fridge", "oven", "windows", "balcony", "garage"]
  addOns          String?       // JSON array
  price           Decimal       @db.Decimal(10, 2)
  status          BookingStatus @default(PENDING)
  paymentHeld     Boolean       @default(false) // MVP: simulates escrow
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer    User    @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  professional User   @relation("ProfessionalBookings", fields: [professionalId], references: [id], onDelete: Cascade)
  review      Review?

  @@index([customerId])
  @@index([professionalId])
  @@index([status])
  @@index([dateTime])
}

model Review {
  id             String   @id @default(cuid())
  bookingId      String   @unique // One review per booking
  professionalId String
  customerId     String
  rating         Int      // 1-5
  comment        String?
  createdAt      DateTime @default(now())

  booking      Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  customer     User                @relation("ReviewsByCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([customerId])
}
